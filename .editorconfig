# ── Diagnostic severities: Reliability (CA2000-CA2026) ────────────────────────
dotnet_diagnostic.CA2000.severity = error   # Dispose objects before losing scope
dotnet_diagnostic.CA2002.severity = error   # Don't lock on objects with weak identity
dotnet_diagnostic.CA2007.severity = suggestion  # Consider calling ConfigureAwait(false) (library code)
dotnet_diagnostic.CA2008.severity = error   # Don't create tasks without passing a TaskScheduler
dotnet_diagnostic.CA2009.severity = error   # Don't call ToImmutableCollection on an immutable collection
dotnet_diagnostic.CA2011.severity = error   # Avoid infinite recursion
dotnet_diagnostic.CA2012.severity = error   # Use ValueTasks correctly
dotnet_diagnostic.CA2013.severity = error   # Don't use ReferenceEquals with value types
dotnet_diagnostic.CA2014.severity = error   # Don't use stackalloc in loops
dotnet_diagnostic.CA2015.severity = error   # Don't define finalizers for types derived from MemoryManager<T>
dotnet_diagnostic.CA2016.severity = error   # Forward CancellationToken parameter
dotnet_diagnostic.CA2017.severity = error   # Parameter count mismatch
dotnet_diagnostic.CA2018.severity = error   # CounterSet.AddMember: incorrect number of arguments
dotnet_diagnostic.CA2019.severity = error   # ThreadStatic fields should not use initializers
dotnet_diagnostic.CA2020.severity = error   # Prevent behavioral change
dotnet_diagnostic.CA2021.severity = error   # Don't call Enumerable.Cast with incompatible type
dotnet_diagnostic.CA2022.severity = error   # Avoid inexact read with Stream.Read
dotnet_diagnostic.CA2025.severity = error   # Don't pass IAsyncDisposable as IDisposable

