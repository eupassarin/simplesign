[src/SimpleSign/Signing/*.cs]
dotnet_diagnostic.IDE0130.severity = none

[samples/**/*.cs]
# Samples are demo code — relax brace enforcement and naming rules
csharp_prefer_braces = true:suggestion
dotnet_diagnostic.IDE0011.severity = suggestion
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1515.severity = none
# Samples don't need XML documentation comments
dotnet_diagnostic.CS1591.severity = none

[benchmarks/**/*.cs]
# BenchmarkDotNet instantiates classes via reflection — suppress false positive
dotnet_diagnostic.CA1812.severity = none

[tests/**/*.cs]
# Test method names use underscore convention (Method_Scenario_Expected)
dotnet_diagnostic.CA1707.severity = none
# Test namespaces don't always match folder structure
dotnet_diagnostic.IDE0130.severity = none
# Test objects (X509Certificate2, streams) are disposed by test framework
dotnet_diagnostic.CA2000.severity = none
# CA2025: flagged on test patterns
dotnet_diagnostic.CA2025.severity = none
# Shared test helpers are public for cross-project access
dotnet_diagnostic.CA1515.severity = none
# Brace style in tests is handled — relax enforcement
csharp_prefer_braces = true:suggestion
dotnet_diagnostic.IDE0011.severity = suggestion
# Tests don't need XML documentation comments
dotnet_diagnostic.CS1591.severity = none
